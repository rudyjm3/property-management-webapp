generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organization ─────────────────────────────────────────────────────────────

model Organization {
  id                   String             @id @default(uuid())
  name                 String             @db.VarChar(200)
  slug                 String             @unique @db.VarChar(200)
  logoUrl              String?            @map("logo_url")
  email                String?            @db.VarChar(320)
  phone                String?            @db.VarChar(20)
  timezone             String             @default("America/Chicago") @db.VarChar(100)
  dateFormat           String?            @map("date_format") @db.VarChar(20)
  planTier             PlanTier           @default(starter) @map("plan_tier")
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  subscriptionStatus            SubscriptionStatus   @default(trialing) @map("subscription_status")
  trialEndsAt                   DateTime?            @map("trial_ends_at")
  stripeAccountId               String?              @unique @map("stripe_account_id")
  stripeAccountStatus           ConnectAccountStatus @default(not_connected) @map("stripe_account_status")
  stripeAccountDetailsSubmitted Boolean              @default(false) @map("stripe_account_details_submitted")
  lateFeeAmount        Decimal            @default(50) @map("late_fee_amount") @db.Decimal(10, 2)
  gracePeriodDays      Int                @default(5) @map("grace_period_days")
  rentDueDay           Int                @default(1) @map("rent_due_day")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  users         User[]
  properties    Property[]
  tenants       Tenant[]
  vendors       Vendor[]
  messages      Message[]
  documents     Document[]
  notifications Notification[]
  ledgerEntries LedgerEntry[]

  @@map("organizations")
}

enum PlanTier {
  starter
  pro
  enterprise
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
}

enum ConnectAccountStatus {
  not_connected
  pending
  active
  restricted
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id               String     @id @default(uuid())
  organizationId   String     @map("organization_id")
  supabaseUserId   String?    @unique @map("supabase_user_id")
  email            String     @db.VarChar(320)
  name             String     @db.VarChar(200)
  phone            String?    @db.VarChar(20)
  role             UserRole   @default(manager)
  status           UserStatus @default(active)
  avatarUrl        String?    @map("avatar_url")
  invitedAt        DateTime?  @map("invited_at")
  lastLoginAt      DateTime?  @map("last_login_at")
  notifRentOverdue String?    @map("notif_rent_overdue") @db.VarChar(20)
  notifWorkOrder   String?    @map("notif_work_order") @db.VarChar(20)
  notifLeaseExpiry String?    @map("notif_lease_expiry") @db.VarChar(20)
  notifNewMessage  String?    @map("notif_new_message") @db.VarChar(20)
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  organization      Organization   @relation(fields: [organizationId], references: [id])
  assignedOrders    WorkOrder[]    @relation("AssignedWorkOrders")
  submittedOrders   WorkOrder[]    @relation("SubmittedWorkOrders")
  sentMessages      Message[]      @relation("SentMessages")
  uploadedDocuments Document[]     @relation("UploadedDocuments")
  notifications     Notification[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("users")
}

enum UserRole {
  owner
  manager
  maintenance
}

enum UserStatus {
  active
  invited
  deactivated
}

// ─── Property ─────────────────────────────────────────────────────────────────

model Property {
  id                    String       @id @default(uuid())
  organizationId        String       @map("organization_id")
  name                  String       @db.VarChar(200)
  type                  PropertyType @default(multifamily)
  address               String       @db.VarChar(500)
  city                  String       @db.VarChar(100)
  state                 String       @db.Char(2)
  zip                   String       @db.VarChar(10)
  country               String       @default("US") @db.VarChar(2)
  jurisdictionNotes     String?      @map("jurisdiction_notes")
  yearBuilt             Int?         @map("year_built")
  unitCount             Int          @default(0) @map("unit_count")
  amenities             String[]
  photoUrl              String?      @map("photo_url")
  notes                 String?
  taxParcelId           String?      @map("tax_parcel_id") @db.VarChar(100)
  insurancePolicyNumber String?      @map("insurance_policy_number") @db.VarChar(200)
  insuranceExpiresAt    DateTime?    @map("insurance_expires_at") @db.Date
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  units        Unit[]
  workOrders   WorkOrder[]

  @@index([organizationId])
  @@map("properties")
}

enum PropertyType {
  multifamily
  single_family
  commercial
  mixed_use
  // Legacy values — kept for backward compat with seed data
  apartment
  condo
  house
}

// ─── Unit ─────────────────────────────────────────────────────────────────────

model Unit {
  id                   String     @id @default(uuid())
  propertyId           String     @map("property_id")
  unitNumber           String     @map("unit_number") @db.VarChar(20)
  floor                Int?
  type                 UnitType?
  bedrooms             Int        @default(1)
  bathrooms            Float      @default(1)
  sqFt                 Int?       @map("sq_ft")
  marketRent           Decimal?   @map("market_rent") @db.Decimal(10, 2)
  rentAmount           Decimal    @map("rent_amount") @db.Decimal(10, 2)
  depositAmount        Decimal    @default(0) @map("deposit_amount") @db.Decimal(10, 2)
  status               UnitStatus @default(vacant)
  availableDate        DateTime?  @map("available_date") @db.Date
  parkingSpaces        String[]   @map("parking_spaces")
  storageUnit          String?    @map("storage_unit") @db.VarChar(100)
  utilityMeterElectric String?    @map("utility_meter_electric") @db.VarChar(100)
  utilityMeterGas      String?    @map("utility_meter_gas") @db.VarChar(100)
  utilityMeterWater    String?    @map("utility_meter_water") @db.VarChar(100)
  address              String?    @db.VarChar(500)
  city                 String?    @db.VarChar(100)
  state                String?    @db.Char(2)
  zip                  String?    @db.VarChar(10)
  notes                String?
  lastInspectionAt     DateTime?  @map("last_inspection_at")
  lastRenovationAt     DateTime?  @map("last_renovation_at") @db.Date
  applianceCount       Int?       @map("appliance_count")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  property   Property    @relation(fields: [propertyId], references: [id])
  leases     Lease[]
  workOrders WorkOrder[]
  messages   Message[]

  @@unique([propertyId, unitNumber])
  @@index([propertyId])
  @@index([status])
  @@map("units")
}

enum UnitType {
  studio
  one_bed
  two_bed
  three_bed
  four_plus_bed
  commercial
}

enum UnitStatus {
  vacant
  occupied
  notice
  maintenance
  unlisted
}

// ─── Tenant ───────────────────────────────────────────────────────────────────

model Tenant {
  id                            String           @id @default(uuid())
  organizationId                String           @map("organization_id")
  supabaseUserId                String?          @unique @map("supabase_user_id")
  // Identity
  email                         String           @db.VarChar(320)
  name                          String           @db.VarChar(200)
  fullLegalName                 String?          @map("full_legal_name") @db.VarChar(200)
  preferredName                 String?          @map("preferred_name") @db.VarChar(200)
  dateOfBirth                   DateTime?        @map("date_of_birth") @db.Date
  phone                         String?          @db.VarChar(20)
  phoneSecondary                String?          @map("phone_secondary") @db.VarChar(20)
  preferredContact              PreferredContact? @map("preferred_contact")
  languagePreference            String?          @map("language_preference") @db.VarChar(10)
  avatarUrl                     String?          @map("avatar_url")
  // Screening — module-flagged, all nullable; populate when Screening module ships
  ssnLast4                      String?          @map("ssn_last4") @db.Char(4)
  ssnFullEncrypted              String?          @map("ssn_full_encrypted")
  govtIdType                    GovernmentIdType? @map("govt_id_type")
  govtIdNumber                  String?          @map("govt_id_number")
  screeningConsentAt            DateTime?        @map("screening_consent_at")
  // Address history
  currentAddress                String?          @map("current_address") @db.VarChar(500)
  previousAddress               String?          @map("previous_address") @db.VarChar(500)
  // Employment & income
  employerName                  String?          @map("employer_name") @db.VarChar(200)
  employerPhone                 String?          @map("employer_phone") @db.VarChar(20)
  monthlyGrossIncome            Decimal?         @map("monthly_gross_income") @db.Decimal(10, 2)
  incomeSource                  IncomeSource?    @map("income_source")
  // Emergency contacts
  emergencyContactName          String?          @map("emergency_contact_name") @db.VarChar(200)
  emergencyContactPhone         String?          @map("emergency_contact_phone") @db.VarChar(20)
  emergencyContact1Relationship String?          @map("emergency_contact_1_relationship") @db.VarChar(100)
  emergencyContact1Email        String?          @map("emergency_contact_1_email") @db.VarChar(320)
  emergencyContact2Name         String?          @map("emergency_contact_2_name") @db.VarChar(200)
  emergencyContact2Phone        String?          @map("emergency_contact_2_phone") @db.VarChar(20)
  emergencyContact2Relationship String?          @map("emergency_contact_2_relationship") @db.VarChar(100)
  // Vehicles & pets (JSONB)
  vehicles                      Json?
  pets                          Json?
  // Portal
  portalStatus                  PortalStatus     @default(never_logged_in) @map("portal_status")
  portalInvitedAt               DateTime?        @map("portal_invited_at")
  notifPaymentConfirm           String?          @map("notif_payment_confirm") @db.VarChar(20)
  notifWorkOrderUpdate          String?          @map("notif_work_order_update") @db.VarChar(20)
  notifMessage                  String?          @map("notif_message") @db.VarChar(20)
  createdAt                     DateTime         @default(now()) @map("created_at")
  updatedAt                     DateTime         @updatedAt @map("updated_at")
  deletedAt                     DateTime?        @map("deleted_at")

  organization      Organization       @relation(fields: [organizationId], references: [id])
  leaseParticipants LeaseParticipant[]
  payments          Payment[]
  workOrders        WorkOrder[]
  receivedMessages  Message[]          @relation("ReceivedMessages")

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("tenants")
}

enum PreferredContact {
  email
  sms
  call
}

enum GovernmentIdType {
  drivers_license
  state_id
  passport
}

enum IncomeSource {
  employment
  self_employed
  benefits
  other
}

enum PortalStatus {
  invited
  active
  never_logged_in
}

// ─── Lease ────────────────────────────────────────────────────────────────────

model Lease {
  id                          String                @id @default(uuid())
  unitId                      String                @map("unit_id")
  // Status & type
  status                      LeaseStatus           @default(active)
  type                        LeaseType?
  // Dates & terms
  startDate                   DateTime              @map("start_date") @db.Date
  endDate                     DateTime              @map("end_date") @db.Date
  moveInDate                  DateTime?             @map("move_in_date") @db.Date
  moveOutDate                 DateTime?             @map("move_out_date") @db.Date
  noticePeriodDays            Int                   @default(30) @map("notice_period_days")
  rentAmount                  Decimal               @map("rent_amount") @db.Decimal(10, 2)
  rentDueDay                  Int                   @default(1) @map("rent_due_day")
  lateFeeAmount               Decimal               @default(0) @map("late_fee_amount") @db.Decimal(10, 2)
  lateFeeGraceDays            Int                   @default(5) @map("late_fee_grace_days")
  // Security deposit
  depositAmount               Decimal               @default(0) @map("deposit_amount") @db.Decimal(10, 2)
  securityDepositPaidAt       DateTime?             @map("security_deposit_paid_at") @db.Date
  securityDepositStatus       SecurityDepositStatus @default(held) @map("security_deposit_status")
  securityDepositReturnedAt   DateTime?             @map("security_deposit_returned_at") @db.Date
  securityDepositReturnAmount Decimal?              @map("security_deposit_return_amount") @db.Decimal(10, 2)
  securityDepositDeductions   Json?                 @map("security_deposit_deductions")
  // Utilities & addenda
  utilitiesIncluded           String[]              @map("utilities_included")
  hasPetAddendum              Boolean               @default(false) @map("has_pet_addendum")
  petDepositAmount            Decimal?              @map("pet_deposit_amount") @db.Decimal(10, 2)
  hasParkingAddendum          Boolean               @default(false) @map("has_parking_addendum")
  parkingFee                  Decimal?              @map("parking_fee") @db.Decimal(10, 2)
  // Occupancy
  occupantCount               Int                   @default(1) @map("occupant_count")
  occupantNames               String[]              @map("occupant_names")
  // Documents & signing
  documentUrl                 String?               @map("document_url")
  esignatureStatus            EsignatureStatus      @default(pending) @map("esignature_status")
  tenantSignedAt              DateTime?             @map("tenant_signed_at")
  managerSignedAt             DateTime?             @map("manager_signed_at")
  renewalOfLeaseId            String?               @map("renewal_of_lease_id")
  notes                       String?
  createdAt                   DateTime              @default(now()) @map("created_at")
  updatedAt                   DateTime              @updatedAt @map("updated_at")
  deletedAt                   DateTime?             @map("deleted_at")

  unit         Unit               @relation(fields: [unitId], references: [id])
  renewalOf    Lease?             @relation("LeaseRenewals", fields: [renewalOfLeaseId], references: [id])
  renewals     Lease[]            @relation("LeaseRenewals")
  participants LeaseParticipant[]
  payments     Payment[]

  @@index([unitId])
  @@index([status])
  @@index([endDate])
  @@map("leases")
}

enum LeaseStatus {
  draft
  active
  month_to_month
  notice_given
  expired
  terminated
}

enum LeaseType {
  fixed_term
  month_to_month
}

enum SecurityDepositStatus {
  held
  partial_return
  full_return
  applied_to_balance
}

enum EsignatureStatus {
  pending
  partially_signed
  completed
}

// ─── Lease Participant ────────────────────────────────────────────────────────

model LeaseParticipant {
  id        String  @id @default(uuid())
  leaseId   String  @map("lease_id")
  tenantId  String  @map("tenant_id")
  isPrimary Boolean @default(false) @map("is_primary")

  lease  Lease  @relation(fields: [leaseId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([leaseId, tenantId])
  @@map("lease_participants")
}

// ─── Payment ──────────────────────────────────────────────────────────────────

model Payment {
  id                    String        @id @default(uuid())
  leaseId               String        @map("lease_id")
  tenantId              String        @map("tenant_id")
  amount                Decimal       @db.Decimal(10, 2)
  type                  PaymentType   @default(rent)
  status                PaymentStatus @default(pending)
  method                PaymentMethod @default(other)
  stripePaymentIntentId String?       @map("stripe_payment_intent_id")
  checkNumber           String?       @map("check_number") @db.VarChar(50)
  referenceNote         String?       @map("reference_note") @db.VarChar(500)
  paidAt                DateTime?     @map("paid_at")
  dueDate               DateTime      @map("due_date") @db.Date
  periodStart           DateTime?     @map("period_start") @db.Date
  periodEnd             DateTime?     @map("period_end") @db.Date
  isLate                Boolean       @default(false) @map("is_late")
  lateFeeApplied        Boolean       @default(false) @map("late_fee_applied")
  lateFeeWaived         Boolean?      @map("late_fee_waived")
  lateFeeWaivedReason   String?       @map("late_fee_waived_reason") @db.VarChar(500)
  notes                 String?
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  deletedAt             DateTime?     @map("deleted_at")

  lease         Lease         @relation(fields: [leaseId], references: [id])
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  ledgerEntries LedgerEntry[]

  @@index([leaseId])
  @@index([tenantId])
  @@index([status])
  @@index([dueDate])
  @@map("payments")
}

enum PaymentType {
  rent
  deposit
  late_fee
  pet_deposit
  parking
  credit
  other
}

enum PaymentStatus {
  pending
  completed
  failed
  waived
  refunded
}

enum PaymentMethod {
  ach
  card
  check
  cash
  money_order
  other
}

// ─── Ledger ───────────────────────────────────────────────────────────────────

enum LedgerEntryType {
  credit
  debit
}

model LedgerEntry {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  paymentId      String?         @map("payment_id")
  type           LedgerEntryType
  amount         Decimal         @db.Decimal(10, 2)
  balanceAfter   Decimal         @map("balance_after") @db.Decimal(10, 2)
  description    String          @db.VarChar(500)
  stripeEventId  String?         @unique @map("stripe_event_id") @db.VarChar(255)
  createdAt      DateTime        @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  payment      Payment?     @relation(fields: [paymentId], references: [id])

  @@index([organizationId, createdAt])
  @@index([paymentId])
  @@map("ledger_entries")
}

// ─── Work Order ───────────────────────────────────────────────────────────────

model WorkOrder {
  id                     String            @id @default(uuid())
  unitId                 String            @map("unit_id")
  propertyId             String?           @map("property_id")
  tenantId               String?           @map("tenant_id")
  assignedToUserId       String?           @map("assigned_to_user_id")
  submittedByUserId      String?           @map("submitted_by_user_id")
  vendorId               String?           @map("vendor_id")
  title                  String?           @db.VarChar(200)
  category               WorkOrderCategory @default(general)
  priority               WorkOrderPriority @default(routine)
  status                 WorkOrderStatus   @default(new_order)
  description            String
  slaDeadlineAt          DateTime?         @map("sla_deadline_at")
  slaBreached            Boolean           @default(false) @map("sla_breached")
  entryPermissionGranted Boolean           @default(false) @map("entry_permission_granted")
  preferredContactWindow String?           @map("preferred_contact_window") @db.VarChar(200)
  scheduledAt            DateTime?         @map("scheduled_at")
  completedAt            DateTime?         @map("completed_at")
  resolutionNotes        String?           @map("resolution_notes")
  laborCost              Decimal?          @map("labor_cost") @db.Decimal(10, 2)
  partsCost              Decimal?          @map("parts_cost") @db.Decimal(10, 2)
  totalCost              Decimal?          @map("total_cost") @db.Decimal(10, 2)
  chargedToTenant        Boolean?          @map("charged_to_tenant")
  tenantChargeAmount     Decimal?          @map("tenant_charge_amount") @db.Decimal(10, 2)
  photosBefore           String[]          @map("photos_before")
  photosAfter            String[]          @map("photos_after")
  videoUrl               String?           @map("video_url") @db.VarChar(1000)
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  unit            Unit      @relation(fields: [unitId], references: [id])
  property        Property? @relation(fields: [propertyId], references: [id])
  tenant          Tenant?   @relation(fields: [tenantId], references: [id])
  assignedTo      User?     @relation("AssignedWorkOrders", fields: [assignedToUserId], references: [id])
  submittedByUser User?     @relation("SubmittedWorkOrders", fields: [submittedByUserId], references: [id])
  vendor          Vendor?   @relation(fields: [vendorId], references: [id])
  messages        Message[]

  @@index([unitId])
  @@index([propertyId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("work_orders")
}

enum WorkOrderCategory {
  plumbing
  electrical
  hvac
  appliance
  pest
  structural
  cosmetic
  grounds
  general
  other
}

enum WorkOrderPriority {
  emergency
  urgent
  routine
  // Legacy values — kept for backward compat
  low
  normal
}

enum WorkOrderStatus {
  new_order
  assigned
  in_progress
  pending_parts
  completed
  closed
  cancelled
}

// ─── Vendor ───────────────────────────────────────────────────────────────────

model Vendor {
  id                 String       @id @default(uuid())
  organizationId     String       @map("organization_id")
  companyName        String       @map("company_name") @db.VarChar(200)
  contactName        String       @map("contact_name") @db.VarChar(200)
  email              String       @db.VarChar(320)
  phonePrimary       String       @map("phone_primary") @db.VarChar(20)
  phoneEmergency     String?      @map("phone_emergency") @db.VarChar(20)
  specialties        String[]
  status             VendorStatus @default(active)
  preferred          Boolean?
  rating             Decimal?     @db.Decimal(3, 1)
  notes              String?
  licenseNumber      String?      @map("license_number") @db.VarChar(200)
  licenseExpiresAt   DateTime?    @map("license_expires_at") @db.Date
  insuranceOnFile    Boolean      @default(false) @map("insurance_on_file")
  insuranceExpiresAt DateTime?    @map("insurance_expires_at") @db.Date
  w9OnFile           Boolean?     @map("w9_on_file")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  workOrders   WorkOrder[]

  @@index([organizationId])
  @@map("vendors")
}

enum VendorStatus {
  active
  inactive
}

// ─── Message ──────────────────────────────────────────────────────────────────

model Message {
  id                String    @id @default(uuid())
  organizationId    String    @map("organization_id")
  threadId          String?   @map("thread_id") @db.VarChar(36)
  unitId            String?   @map("unit_id")
  workOrderId       String?   @map("work_order_id")
  subject           String?   @db.VarChar(500)
  senderUserId      String?   @map("sender_user_id")
  recipientTenantId String?   @map("recipient_tenant_id")
  body              String
  attachmentUrl     String?   @map("attachment_url")
  readAt            DateTime? @map("read_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  sender       User?        @relation("SentMessages", fields: [senderUserId], references: [id])
  recipient    Tenant?      @relation("ReceivedMessages", fields: [recipientTenantId], references: [id])
  unit         Unit?        @relation(fields: [unitId], references: [id])
  workOrder    WorkOrder?   @relation(fields: [workOrderId], references: [id])

  @@index([organizationId])
  @@index([recipientTenantId])
  @@index([threadId])
  @@map("messages")
}

// ─── Document ─────────────────────────────────────────────────────────────────

model Document {
  id               String              @id @default(uuid())
  organizationId   String              @map("organization_id")
  entityType       DocumentEntityType  @map("entity_type")
  entityId         String              @map("entity_id")
  name             String              @db.VarChar(500)
  s3Key            String              @map("s3_key")
  mimeType         String              @map("mime_type") @db.VarChar(100)
  sizeBytes        Int                 @map("size_bytes")
  uploadedByUserId String              @map("uploaded_by_user_id")
  visibleToTenant  Boolean             @default(false) @map("visible_to_tenant")
  docCategory      DocumentCategory?   @map("doc_category")
  label            String?             @db.VarChar(200)
  createdAt        DateTime            @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  uploadedBy   User         @relation("UploadedDocuments", fields: [uploadedByUserId], references: [id])

  @@index([organizationId])
  @@index([entityType, entityId])
  @@map("documents")
}

enum DocumentEntityType {
  property
  unit
  lease
  tenant
  work_order
  vendor
}

enum DocumentCategory {
  lease
  inspection
  insurance
  id
  photo
  other
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  organizationId String    @map("organization_id")
  type           String    @db.VarChar(100)
  title          String    @db.VarChar(500)
  body           String
  readAt         DateTime? @map("read_at")
  actionUrl      String?   @map("action_url")
  createdAt      DateTime  @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([userId, readAt])
  @@map("notifications")
}
