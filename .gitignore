# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/
.expo/
.expo-shared/

# Environment variables — NEVER commit these
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example is intentionally NOT ignored — it is the template

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test coverage
coverage/
.nyc_output/

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# IDE and editor files
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
# Shared VSCode settings are committed; user-specific are not
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# Turborepo
.turbo/

# Prisma
# Generated client is not committed — runs via postinstall
packages/db/node_modules/

# Vercel
.vercel

# Expo
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/
android/
ios/

# Misc
*.pem
.cache/
tmp/
temp/
