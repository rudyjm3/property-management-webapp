# PropFlow Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# See docs/SETUP.md for instructions on obtaining each value.

# ─────────────────────────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# The public URL of the web app (used for email links, redirects)
APP_URL=http://localhost:3000

# The public URL of the API (used by web + mobile to make requests)
API_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL via Docker)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Default Docker Compose values are pre-filled below
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://propflow:propflow_dev@localhost:5432/propflow_dev

# ─────────────────────────────────────────────────────────────────────────────
# CACHE (Redis via Docker)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# AUTH (Supabase)
# Get these from: https://supabase.com → Project Settings → API
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# WARNING: Service role key has full DB access — only used server-side, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT secret used to verify Supabase tokens on the API
# Get from: Supabase → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─────────────────────────────────────────────────────────────────────────────
# PAYMENTS (Stripe)
# Get these from: https://dashboard.stripe.com → Developers → API Keys
# Use test keys (sk_test_... / pk_test_...) for development
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Webhook secret — get from: Stripe Dashboard → Webhooks → signing secret
# For local dev, use the Stripe CLI: stripe listen --forward-to localhost:3001/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─────────────────────────────────────────────────────────────────────────────
# FILE STORAGE (AWS S3)
# Create a bucket and IAM user with S3 permissions
# ─────────────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=propflow-documents-dev

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (Resend)
# Get from: https://resend.com → API Keys
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=no-reply@yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# SMS (Twilio)
# Get from: https://console.twilio.com
# ─────────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# CRON SECRET
# A long random string used to authenticate job-trigger endpoints.
# Set the same value in your scheduler (Railway cron, Vercel cron, etc.)
# and pass it as: Authorization: Bearer <value>
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────
CRON_SECRET=your_cron_secret_here
